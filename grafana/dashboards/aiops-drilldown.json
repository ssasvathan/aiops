{
  "uid": "aiops-drilldown",
  "title": "aiOps \u2014 Topic Drill-Down",
  "description": "Per-topic SRE triage view with evidence status, findings, and diagnosis details. Panel IDs reserved: 100\u2013199 (drill-down only; main dashboard uses 1\u201399).",
  "schemaVersion": 39,
  "version": 4,
  "tags": ["aiops"],
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "[← Back to Overview](/d/aiops-main)"
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Topic health",
      "description": "Total findings processed for the selected topic as a proxy for topic pipeline activity and health status.",
      "transparent": true,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#E8913A", "value": 1 },
              { "color": "#6BAD64", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_findings_total{topic=\"$topic\"}[$__range]))",
          "refId": "A",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Evidence status",
      "description": "Per-metric evidence state for the selected topic — shows whether evidence is PRESENT, STALE, UNKNOWN, or ABSENT for each monitored metric.",
      "transparent": true,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value",
        "text": { "valueSize": 14 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6BAD64", "value": null },
              { "color": "#E8913A", "value": 1 },
              { "color": "#7A7A7A", "value": 2 },
              { "color": "#D94452", "value": 3 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "PRESENT", "color": "#6BAD64" },
                "1": { "text": "STALE", "color": "#E8913A" },
                "2": { "text": "UNKNOWN", "color": "#7A7A7A" },
                "3": { "text": "ABSENT", "color": "#D94452" }
              }
            }
          ],
          "noValue": "Awaiting data"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "aiops_evidence_status{topic=\"$topic\"}",
          "refId": "A",
          "legendFormat": "{{metric_key}}"
        }
      ]
    },
    {
      "id": 110,
      "type": "timeseries",
      "title": "Per-topic findings over time",
      "description": "Rate of findings processed for the selected topic over the time window, broken down by final action taken.",
      "transparent": true,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4F87DB" },
          "noValue": "0",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(final_action) (rate(aiops_findings_total{topic=\"$topic\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{final_action}}"
        }
      ]
    },
    {
      "id": 120,
      "type": "table",
      "title": "Findings by topic",
      "description": "Findings breakdown by anomaly family and final action for the selected topic, enabling action decision tracing per finding type.",
      "transparent": true,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 13 },
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4F87DB" },
          "noValue": "No findings this period"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(anomaly_family, final_action) (increase(aiops_findings_total{topic=\"$topic\"}[$__range]))",
          "refId": "A",
          "legendFormat": "{{anomaly_family}} \u2192 {{final_action}}"
        }
      ]
    },
    {
      "id": 130,
      "type": "stat",
      "title": "Diagnosis count",
      "description": "Total LLM diagnosis completions for the selected topic in the selected time window.",
      "transparent": true,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 19 },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#7A7A7A" },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_diagnosis_completed_total{topic=\"$topic\"}[$__range]))",
          "refId": "A",
          "legendFormat": "Diagnoses"
        }
      ]
    },
    {
      "id": 131,
      "type": "stat",
      "title": "Gating evaluations",
      "description": "Total gating evaluations for the selected topic as a proxy for action decision activity and outbox processing.",
      "transparent": true,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 19 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#D94452", "value": null },
              { "color": "#E8913A", "value": 1 },
              { "color": "#6BAD64", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_gating_evaluations_total{topic=\"$topic\"}[$__range]))",
          "refId": "A",
          "legendFormat": "Evaluations"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "topic",
        "type": "query",
        "label": "Topic",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(aiops_findings_total, topic)",
        "query": {
          "query": "label_values(aiops_findings_total, topic)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "options": [],
        "current": {}
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": []
}
