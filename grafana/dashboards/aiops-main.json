{
  "uid": "aiops-main",
  "title": "aiOps \u2014 Pipeline Intelligence",
  "description": "Stakeholder narrative and operational detail for the aiOps triage pipeline. Panel IDs reserved: 1\u201399 (main dashboard only; drill-down uses 100\u2013199).",
  "schemaVersion": 39,
  "version": 11,
  "tags": ["aiops"],
  "timezone": "browser",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "time_options": ["1h", "6h", "24h", "7d", "30d"]
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline health",
      "description": "Aggregate health signal — green: all systems operational, amber: degraded performance, red: pipeline unavailable. (Proxy signal pending dedicated health gauge recording rule.)",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6BAD64", "value": null },
              { "color": "#E8913A", "value": 1 },
              { "color": "#D94452", "value": 2 }
            ]
          },
          "noValue": "Awaiting first pipeline cycle",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "HEALTHY" }, "1": { "text": "DEGRADED" }, "2": { "text": "UNAVAILABLE" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(aiops_findings_total) or vector(0)",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Anomalies detected & acted on",
      "description": "Total anomalies the platform detected and dispatched an action for within the selected time window — the core P&L metric.",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 5 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#6BAD64" },
          "unit": "short",
          "decimals": 0,
          "noValue": "Awaiting first pipeline cycle",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_findings_total[$__range])) or vector(0)",
          "refId": "A",
          "legendFormat": "Actioned in window"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Topic health",
      "description": "Per-topic health overview — click any tile to drill down into evidence status, findings, and diagnosis for that topic.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "titleSize": 14, "valueSize": 16 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true,
          "limit": 10
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6BAD64", "value": null },
              { "color": "#E8913A", "value": 1 },
              { "color": "#D94452", "value": 2 }
            ]
          },
          "noValue": "Awaiting first pipeline cycle",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "HEALTHY" },
                "1": { "text": "WARNING" },
                "2": { "text": "CRITICAL" }
              }
            }
          ],
          "links": [
            {
              "title": "View topic details",
              "url": "/d/aiops-drilldown?var-topic=${__field.labels.topic}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(topic) (increase(aiops_findings_total[$__range])) or vector(0)",
          "refId": "A",
          "legendFormat": "{{topic}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "type": "text",
      "title": "",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "options": {
        "content": "",
        "mode": "markdown"
      },
      "transparent": true
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Baseline deviation overlay",
      "description": "Actual detection rate (blue line) vs expected-range band (shaded) — amber markers indicate AI-detected deviations.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "transparent": true,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4F87DB" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "gradientMode": "none",
            "spanNulls": false,
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "showPoints": "never"
          },
          "noValue": "Awaiting data"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "upper_bound" },
            "properties": [
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "custom.fillBelowTo", "value": "lower_bound" },
              { "id": "custom.fillOpacity", "value": 12 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4F87DB" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "lower_bound" },
            "properties": [
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4F87DB" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(aiops_findings_total[$__rate_interval])) or vector(0)",
          "refId": "A",
          "legendFormat": "Detections"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(aiops_findings_total[$__rate_interval])) * 1.3 + 0.1 or vector(0.1)",
          "refId": "B",
          "legendFormat": "upper_bound"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "vector(0)",
          "refId": "C",
          "legendFormat": "lower_bound"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "type": "text",
      "title": "",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "options": {
        "content": "",
        "mode": "markdown"
      },
      "transparent": true
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Gating intelligence funnel",
      "description": "Per-gate suppression counts showing how many findings each gate rule eliminated before dispatch — the noise-to-signal funnel.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "transparent": true,
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "text": {
          "titleSize": 14,
          "valueSize": 16
        },
        "minVizWidth": 0,
        "minVizHeight": 16
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#6BAD64", "value": 0 }
            ]
          },
          "noValue": "0",
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4F87DB" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(gate_id, outcome) (increase(aiops_gating_evaluations_total[$__range]))",
          "refId": "A",
          "legendFormat": "{{gate_id}} ({{outcome}})"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Action distribution",
      "description": "Rate of findings dispatched over time, broken down by action type (OBSERVE, NOTIFY, TICKET, PAGE) — confirms the platform maintains a stable, low-noise action profile.",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 30 },
      "transparent": true,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4F87DB" },
          "custom": {
            "stacking": { "mode": "normal" },
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "showPoints": "never"
          },
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "OBSERVE" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4F87DB" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "NOTIFY" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#E8913A" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "TICKET" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#D94452" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "PAGE" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#6BAD64" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(final_action) (rate(aiops_findings_total[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{final_action}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Anomaly family breakdown",
      "description": "Total findings in the selected time window grouped by anomaly family — shows which detection patterns (consumer lag, volume drop, throughput proxy, baseline deviation) are most active.",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 30 },
      "transparent": true,
      "options": {
        "orientation": "horizontal",
        "sort": "desc",
        "text": {
          "titleSize": 14,
          "valueSize": 14
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#6BAD64", "value": 0 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(anomaly_family) (increase(aiops_findings_total[$__range]))",
          "refId": "A",
          "legendFormat": "{{anomaly_family}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Diagnosis invocations",
      "description": "Total LLM diagnosis engine invocations completed in the selected time window.",
      "gridPos": { "h": 2, "w": 12, "x": 12, "y": 36 },
      "transparent": true,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#7A7A7A" },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_diagnosis_completed_total[$__range]))",
          "refId": "A",
          "legendFormat": "Invocations"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Fault domain identification rate",
      "description": "Percentage of completed diagnoses where a specific fault domain was identified.",
      "gridPos": { "h": 2, "w": 12, "x": 12, "y": 38 },
      "transparent": true,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#E8913A", "value": 0.5 },
              { "color": "#6BAD64", "value": 0.8 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_diagnosis_completed_total{fault_domain_present=\"true\"}[$__range])) / sum(increase(aiops_diagnosis_completed_total[$__range]))",
          "refId": "A",
          "legendFormat": "Fault domain rate"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 12,
      "type": "barchart",
      "title": "Confidence distribution",
      "description": "Distribution of diagnosis confidence levels (LOW, MEDIUM, HIGH) over the selected time window.",
      "gridPos": { "h": 3, "w": 12, "x": 12, "y": 40 },
      "transparent": true,
      "options": {
        "orientation": "horizontal",
        "sort": "desc",
        "text": {
          "titleSize": 14,
          "valueSize": 14
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#6BAD64", "value": 0 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(confidence) (increase(aiops_diagnosis_completed_total[$__range]))",
          "refId": "A",
          "legendFormat": "{{confidence}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "High confidence rate",
      "description": "Percentage of completed diagnoses that achieved HIGH confidence level.",
      "gridPos": { "h": 2, "w": 12, "x": 12, "y": 43 },
      "transparent": true,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#E8913A", "value": 0.5 },
              { "color": "#6BAD64", "value": 0.7 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_diagnosis_completed_total{confidence=\"HIGH\"}[$__range])) / sum(increase(aiops_diagnosis_completed_total[$__range]))",
          "refId": "A",
          "legendFormat": "High confidence rate"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Pipeline capability stack",
      "description": "Total findings processed as a proxy for overall pipeline stage activity and operational status.",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 36 },
      "transparent": true,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#7A7A7A", "value": null },
              { "color": "#6BAD64", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_findings_total[$__range]))",
          "refId": "A",
          "legendFormat": "Pipeline activity"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Pipeline throughput",
      "description": "Total findings processed in the selected window, with sparkline to show throughput trend over time.",
      "gridPos": { "h": 2, "w": 12, "x": 0, "y": 41 },
      "transparent": true,
      "options": {
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#7A7A7A" },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_findings_total[$__range]))",
          "refId": "A",
          "legendFormat": "Findings processed"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Outbox health",
      "description": "Gating evaluations processed in the selected window as a proxy for outbox processing activity.",
      "gridPos": { "h": 2, "w": 12, "x": 0, "y": 43 },
      "transparent": true,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "text": { "valueSize": 28 },
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#D94452", "value": null },
              { "color": "#E8913A", "value": 1 },
              { "color": "#6BAD64", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(aiops_gating_evaluations_total[$__range]))",
          "refId": "A",
          "legendFormat": "Outbox health"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "increase(aiops_findings_total[$__rate_interval]) > 0",
        "hide": false,
        "iconColor": "#E8913A",
        "name": "Detection events",
        "step": "60s",
        "titleFormat": "Deviation detected",
        "type": "dashboard"
      }
    ]
  },
  "links": []
}
