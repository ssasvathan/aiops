APP_ENV=prod

# Kafka (Production cluster)
KAFKA_BOOTSTRAP_SERVERS=<PROD_KAFKA_BOOTSTRAP_SERVERS>
KAFKA_SECURITY_PROTOCOL=<PROD_KAFKA_SECURITY_PROTOCOL>

# Postgres (Production)
DATABASE_URL=postgresql+psycopg://<PROD_DB_USER>:<PROD_DB_PASSWORD>@<PROD_DB_HOST>:5432/<PROD_DB_NAME>

# Redis (Production)
REDIS_URL=redis://:<PROD_REDIS_PASSWORD>@<PROD_REDIS_HOST>:6379/0

# S3 / NetApp (Production)
S3_ENDPOINT_URL=<PROD_S3_ENDPOINT_URL>
S3_ACCESS_KEY=<PROD_S3_ACCESS_KEY>
S3_SECRET_KEY=<PROD_S3_SECRET_KEY>
S3_BUCKET=<PROD_S3_BUCKET>

# Integration modes
INTEGRATION_MODE_PD=<PROD_PD_MODE>
INTEGRATION_MODE_SLACK=<PROD_SLACK_MODE>
INTEGRATION_MODE_SN=<PROD_SN_MODE>
INTEGRATION_MODE_LLM=<PROD_LLM_MODE>
