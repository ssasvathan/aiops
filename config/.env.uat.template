APP_ENV=uat

# Kafka (UAT cluster)
KAFKA_BOOTSTRAP_SERVERS=<UAT_KAFKA_BOOTSTRAP_SERVERS>
KAFKA_SECURITY_PROTOCOL=<UAT_KAFKA_SECURITY_PROTOCOL>

# Postgres (UAT)
DATABASE_URL=postgresql+psycopg://<UAT_DB_USER>:<UAT_DB_PASSWORD>@<UAT_DB_HOST>:5432/<UAT_DB_NAME>

# Redis (UAT)
REDIS_URL=redis://:<UAT_REDIS_PASSWORD>@<UAT_REDIS_HOST>:6379/0

# S3 / NetApp (UAT)
S3_ENDPOINT_URL=<UAT_S3_ENDPOINT_URL>
S3_ACCESS_KEY=<UAT_S3_ACCESS_KEY>
S3_SECRET_KEY=<UAT_S3_SECRET_KEY>
S3_BUCKET=<UAT_S3_BUCKET>

# Integration modes
INTEGRATION_MODE_PD=<UAT_PD_MODE>
INTEGRATION_MODE_SLACK=<UAT_SLACK_MODE>
INTEGRATION_MODE_SN=<UAT_SN_MODE>
INTEGRATION_MODE_LLM=<UAT_LLM_MODE>
