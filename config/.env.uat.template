APP_ENV=uat

# Kafka (UAT cluster)
KAFKA_BOOTSTRAP_SERVERS=<UAT_KAFKA_BOOTSTRAP_SERVERS>
KAFKA_SECURITY_PROTOCOL=<UAT_KAFKA_SECURITY_PROTOCOL>
KAFKA_COLD_PATH_CONSUMER_GROUP=aiops-cold-path-diagnosis
KAFKA_COLD_PATH_POLL_TIMEOUT_SECONDS=1.0

# Postgres (UAT)
DATABASE_URL=postgresql+psycopg://<UAT_DB_USER>:<UAT_DB_PASSWORD>@<UAT_DB_HOST>:5432/<UAT_DB_NAME>

# Redis (UAT)
REDIS_URL=redis://:<UAT_REDIS_PASSWORD>@<UAT_REDIS_HOST>:6379/0

# S3 / NetApp (UAT)
S3_ENDPOINT_URL=<UAT_S3_ENDPOINT_URL>
S3_ACCESS_KEY=<UAT_S3_ACCESS_KEY>
S3_SECRET_KEY=<UAT_S3_SECRET_KEY>
S3_BUCKET=<UAT_S3_BUCKET>

# Integration modes
INTEGRATION_MODE_PD=<UAT_PD_MODE>
INTEGRATION_MODE_SLACK=<UAT_SLACK_MODE>
INTEGRATION_MODE_SN=<UAT_SN_MODE>
INTEGRATION_MODE_LLM=<UAT_LLM_MODE>

# Hot-path topology registry
TOPOLOGY_REGISTRY_PATH=config/topology-registry.yaml
STAGE2_PEAK_HISTORY_MAX_DEPTH=4320  # 15 days x 288 samples/day (5-min intervals)
SHARD_LEASE_TTL_SECONDS=294  # ceil(p95=263s + safety_margin=31s), calibrated 2026-03-29 from UAT sample window; must stay < interval=300s

# OTLP metrics
OTLP_METRICS_ENDPOINT=<UAT_OTLP_METRICS_ENDPOINT>
OTLP_METRICS_PROTOCOL=http/protobuf
OTLP_METRICS_HEADERS=<UAT_OTLP_METRICS_HEADERS>
OTLP_METRICS_EXPORT_INTERVAL_MILLIS=60000
OTLP_METRICS_TIMEOUT_MILLIS=10000
OTLP_SERVICE_NAME=aiops-triage-pipeline
OTLP_SERVICE_VERSION=0.1.0
