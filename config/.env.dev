APP_ENV=dev

# Kafka (DEV cluster — no real secrets)
KAFKA_BOOTSTRAP_SERVERS=kafka-dev.internal:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Postgres (DEV — connection placeholder)
DATABASE_URL=postgresql+psycopg://aiops:aiops@postgres-dev.internal:5432/aiops

# Redis (DEV)
REDIS_URL=redis://redis-dev.internal:6379/0

# MinIO / S3 (DEV)
S3_ENDPOINT_URL=http://minio-dev.internal:9000
S3_ACCESS_KEY=dev-access-key
S3_SECRET_KEY=dev-secret-key
S3_BUCKET=aiops-cases-dev

# Integration modes (LOG for dev by default — override per deployment)
INTEGRATION_MODE_PD=LOG
INTEGRATION_MODE_SLACK=LOG
INTEGRATION_MODE_SN=LOG
INTEGRATION_MODE_LLM=LOG

# OTLP metrics (Dynatrace endpoint in DEV)
OTLP_METRICS_ENDPOINT=<DEV_OTLP_METRICS_ENDPOINT>
OTLP_METRICS_PROTOCOL=http/protobuf
OTLP_METRICS_HEADERS=<DEV_OTLP_METRICS_HEADERS>
OTLP_METRICS_EXPORT_INTERVAL_MILLIS=60000
OTLP_METRICS_TIMEOUT_MILLIS=10000
OTLP_SERVICE_NAME=aiops-triage-pipeline
OTLP_SERVICE_VERSION=0.1.0
